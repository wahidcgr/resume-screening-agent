# Copy this file to .env (or export these vars in your shell) and fill in your key.

# Required for full LLM-based extraction and scoring.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Optional: override the Groq model used for extraction/scoring.
# Default: openai/gpt-oss-120b
GROQ_MODEL=openai/gpt-oss-120b